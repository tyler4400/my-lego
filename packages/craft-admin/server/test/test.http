@email_username = tyler{{$timestamp}}@test.com
@email_password = 12345678
@phone_number = 13800000000

### login
POST {{host}}:{{port}}/api/users/login
Content-Type: application/json

{
  "email": "tyler1766558092@test.com",
  "password": "{{email_password}}"
}

### signup
POST {{host}}:{{port}}/api/users/signup
Content-Type: application/json

{
  "email": "{{$random.email}}",
  "password": "12345678",
  "confirmPwd": "12345678"
}

### 当前用户信息 （未登录时 会401）
GET {{host}}:{{port}}/api/users/current

### 登出
POST {{host}}:{{port}}/api/users/logout

### 用户列表（auth）
GET {{host}}:{{port}}/api/users

### 设置用户的role
PATCH {{host}}:{{port}}/api/users/6a338bb99f36fc781ce0230b
Content-Type: application/json

{
  "role": "normal"
}
